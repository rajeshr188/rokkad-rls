# Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-secure-random-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database engine: sqlite or postgres
DB_ENGINE=postgres

# PostgreSQL settings
# DB_USER/DB_PASSWORD should be runtime app role credentials.
# For migrations, temporarily switch to migration/owner role credentials.
# Runtime role must not have BYPASSRLS and should not own tenant tables.
DB_NAME=rls_rokkad
DB_USER=rls_rokkad_user
DB_PASSWORD=replace_me
DB_HOST=127.0.0.1
DB_PORT=5432
